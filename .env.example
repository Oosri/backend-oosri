# =============================================================================
# SERVER
# =============================================================================
NODE_ENV=development
PORT=5000

# =============================================================================
# DATABASE
# =============================================================================
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDISHOST=localhost
REDISPORT=6379
REDISUSER=
REDISPASSWORD=

# =============================================================================
# AUTH / JWT
# =============================================================================
JWT_SECRET=<your-jwt-secret>
SALT_ROUNDS=12
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/buyer/google/callback

# =============================================================================
# COOKIES
# =============================================================================
COOKIE_DOMAIN=localhost
BUYER_AUTH_COOKIE_SECURE=false
BUYER_AUTH_COOKIE_SAME_SITE=lax

# =============================================================================
# FRONTEND URLS
# =============================================================================
FRONTEND_URL=http://localhost:3000
BUYER_FRONTEND_URL=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3001
ALLOW_DEV_ORIGINS=true

# =============================================================================
# PAYMENTS
# =============================================================================
STRIPE_PAYMENT_TEST_KEY=sk_test_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>
PAYSTACK_SECRET_KEY=sk_test_<your-paystack-secret-key>
PLATFORM_FEE_PERCENT=10

# =============================================================================
# CLOUDINARY
# =============================================================================
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
CLOUDINARY_PRODUCTS_FOLDER=products
CLOUDINARY_PRODUCTS_TRANSFORM=c_limit,w_1200,q_auto
CLOUDINARY_PROFILE_PICS_FOLDER=profile_pics
CLOUDINARY_DOCUMENTS_FOLDER=documents
CLOUDINARY_SELLER_DOCS_FOLDER=seller_docs

# =============================================================================
# EMAIL (ZeptoMail — primary)
# =============================================================================
ZEPTOMAIL_TOKEN=<your-zeptomail-token>
ZEPTOMAIL_URL=https://api.zeptomail.com/
SUPPORT_EMAIL=support@oosri.com
EMAIL_TEAM=team@oosri.com
LOGISTICS_PROCESSING_EMAIL=logistics@oosri.com

# =============================================================================
# EMAIL (SMTP fallback)
# =============================================================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=<smtp-username>
EMAIL_PASS=<smtp-password>
EMAIL_SENDER=noreply@oosri.com

# =============================================================================
# ALGOLIA
# =============================================================================
ALGOLIA_APP_ID=<your-algolia-app-id>
ALGOLIA_SEARCH_API_KEY=<your-algolia-api-key>
ALGOLIA_INDEX_NAME=products

# =============================================================================
# SHIPPING — FEDEX
# =============================================================================
FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_CLIENT_ID=<your-fedex-client-id>
FEDEX_CLIENT_KEY=<your-fedex-client-key>
FEDEX_CLIENT_SECRET=<your-fedex-client-secret>
FEDEX_ACCOUNT_NUMBER=<your-fedex-account-number>

# =============================================================================
# SHIPPING — DHL
# =============================================================================
DHL_API_BASE_URL=https://express.api.dhl.com/mydhlapi/test
DHL_API_USERNAME=<your-dhl-username>
DHL_API_PASSWORD=<your-dhl-password>
DHL_EXPORT_ACCOUNT=<your-dhl-export-account>
DHL_PICKUP_COMPANY_NAME=Oosri Global
DHL_PICKUP_CONTACT_NAME=<contact-name>
DHL_PICKUP_CONTACT_EMAIL=<contact-email>
DHL_PICKUP_CONTACT_PHONE=<contact-phone>
DHL_PICKUP_ADDRESS_LINE1=<address-line-1>
DHL_PICKUP_ADDRESS_LINE2=
DHL_PICKUP_CITY=Lagos
DHL_PICKUP_COUNTY=Lagos
DHL_PICKUP_POSTAL_CODE=100001
DHL_PICKUP_COUNTRY_CODE=NG
DHL_PICKUP_LOCATION=RECEPTION
DHL_PICKUP_LOCATION_TYPE=BUSINESS
DHL_PICKUP_PRODUCT_CODE=P
DHL_PICKUP_CLOSE_TIME=18:00
DHL_PICKUP_DECLARED_VALUE_CURRENCY=USD

# =============================================================================
# SHIPPING — HAULAM
# =============================================================================
HAULAM_SECRET_KEY=<your-haulam-secret-key>
HAULAM_ENVIRONMENT=sandbox
HAULAM_SERVICE_TYPE=standard

# =============================================================================
# DEFAULT SHIPPING PROVIDER
# =============================================================================
DEFAULT_PROVIDER=fedex

# =============================================================================
# FX RATES
# =============================================================================
FX_API_KEY=<your-fx-api-key>
FX_API_URL=https://api.exchangerate-api.com/v4/latest/USD
FX_SPREAD_PERCENT=1
FX_TTL_MS=3600000
FX_TIMEOUT_MS=5000

# =============================================================================
# SCHEDULER
# =============================================================================
RUN_AGENDA_SCHEDULER=true
ENABLE_SELF_PING=false
