{
  "name": "oosri-ecommerce-api",
  "version": "1.0.0",
  "description": "An Online Ecommerce Website Store API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/ server.js --ext .js",
    "lint:fix": "eslint src/ server.js --ext .js --fix",
    "test:ci": "jest --runInBand --forceExit --json --outputFile=test-reports/jest-results.json",
    "test:coverage": "jest --runInBand --forceExit --coverage --coverageDirectory=test-reports/coverage",
    "load:run": "k6 run __tests__/load/k6/main.js",
    "load:report": "artillery report test-reports/load-results.json --output test-reports/load-report.html",
    "dashboard": "node scripts/serve-dashboard.js",
    "test:all": "npm run test:ci && npm run dashboard",
    "load:smoke": "K6_PROFILE=smoke  k6 run __tests__/load/k6/main.js",
    "load:stress": "K6_PROFILE=stress k6 run __tests__/load/k6/main.js",
    "load:spike": "K6_PROFILE=spike  k6 run __tests__/load/k6/main.js",
    "load:soak": "K6_PROFILE=soak   k6 run __tests__/load/k6/main.js"
  },
  "keywords": [],
  "author": "https://github.com/deedee-code",
  "license": "ISC",
  "dependencies": {
    "@algolia/client-search": "^5.6.1",
    "@bull-board/api": "^6.16.2",
    "@bull-board/express": "^6.16.2",
    "@hapi/joi": "^15.1.1",
    "agenda": "^5.0.0",
    "algoliasearch": "^4.20.0",
    "axios": "^1.7.9",
    "basic-ftp": "^5.0.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "bullmq": "^5.66.5",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^4.3.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "ftp": "^0.3.10",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "leo-profanity": "^1.9.0",
    "moment": "^2.30.1",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "paystack": "^2.0.1",
    "socket.io": "^4.8.3",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^11.0.0",
    "stripe": "^18.5.0",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "zeptomail": "^7.0.0"
  },
  "devDependencies": {
    "artillery": "^1.7.9",
    "autocannon": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n": "^16.6.2",
    "jest": "^30.4.1",
    "nodemon": "^3.1.4",
    "proxyquire": "^2.1.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 30000,
    "verbose": true
  }
}
